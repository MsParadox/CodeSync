# ════════════════════════════════════════════════════════════════
#  CodeSync — Server environment
#  Copy to `.env` and fill in real values.
# ════════════════════════════════════════════════════════════════

NODE_ENV=development          # development | production | test
PORT=4000

# ── Database (MongoDB) ──────────────────────────────────────────
# Local (docker-compose service name "mongodb"):
MONGODB_URI=mongodb://codesync:codesync_local_pass@localhost:27017/codesync?authSource=admin
# Production (MongoDB Atlas M0 free tier):
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/codesync?retryWrites=true&w=majority

# ── Cache / Presence / Pub-Sub (Redis) ──────────────────────────
REDIS_URL=redis://localhost:6379
# Production (Upstash — note the rediss:// TLS scheme):
# REDIS_URL=rediss://default:password@host.upstash.io:6380

# ── Auth (CHANGE THESE IN PRODUCTION) ───────────────────────────
# Generate each with:  openssl rand -hex 32
JWT_SECRET=dev_jwt_secret_change_in_production_32chars_minimum
REFRESH_TOKEN_SECRET=dev_refresh_secret_change_in_production_minimum
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── CORS / Origins ───────────────────────────────────────────────
#   http://localhost            → via Nginx on port 80 (docker-compose)
#   https://yourdomain.com      → production
CLIENT_URL=http://localhost
# Optional comma-separated extra allowed origins:
# EXTRA_ORIGINS=https://www.yourdomain.com,https://app.yourdomain.com

# ── Code Execution Engine ───────────────────────────────────────
# EXEC_ENGINE selects HOW user code runs (the only Docker/VM-bound part):
#   docker  (default) → self-hosted sandbox; needs a Docker daemon / VM.
#   judge0            → remote Judge0 API; NO Docker/VM needed, so the app
#                       can deploy on card-free PaaS (Render/Koyeb/Vercel).
EXEC_ENGINE=docker

# ── Judge0 (used when EXEC_ENGINE=judge0) ───────────────────────
# Default is the KEYLESS public CE instance (rate-limited, best for demos).
JUDGE0_API_URL=https://ce.judge0.com
# For higher limits use a RapidAPI Judge0 key (free tier, no card) or your
# own self-hosted Judge0, then set these:
# JUDGE0_API_KEY=<your RapidAPI key>
# JUDGE0_API_HOST=judge0-ce.p.rapidapi.com
# Override a language id if your instance differs (e.g. JUDGE0_LANG_PYTHON=71)

# ── Code Execution Sandbox (Docker engine only) ─────────────────
# The server talks to the host Docker daemon through this socket and
# launches one throwaway, network-isolated container per run.
DOCKER_SOCKET=/var/run/docker.sock
MAX_CONCURRENT_EXECUTIONS=10   # global cap on simultaneous containers
EXECUTION_TIMEOUT_MS=10000     # per-run wall-clock limit (TLE)
EXEC_MEMORY_MB=256             # per-container RAM cap (raise if javac/rustc OOM)
EXECUTION_RATE_LIMIT=10        # runs per minute per user
MAX_STDOUT_BYTES=1048576       # 1 MB stdout cap
MAX_STDERR_BYTES=262144        # 256 KB stderr cap

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info                 # debug | http | info | warn | error
