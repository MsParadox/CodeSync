# eslint-plugin-react-hooks@4.6.2 declares peerDependencies eslint ^3-8,
# but package.json pins eslint ^9.5.0 (eslint 9 flat-config). This is a
# common, harmless mismatch (the plugin works fine with eslint 9 in
# practice; the peer-range metadata just hasn't been bumped). Without
# this, BOTH `npm install` (lock-file generation) and `npm ci` (Docker
# build, client/Dockerfile.dev) fail immediately with ERESOLVE — the
# client container never builds.
legacy-peer-deps=true
