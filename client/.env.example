# API base URL — when set, MUST end in /api (server mounts routes under /api).
# Leave empty to use same-origin "/api" (works behind the Nginx proxy).
VITE_API_URL=
# Socket.IO connects to the server ORIGIN (no /api path).
VITE_SOCKET_URL=

# Local dev without Nginx (direct Vite + Node):
# VITE_API_URL=http://localhost:4000/api
# VITE_SOCKET_URL=http://localhost:4000

# Separate frontend deployment (e.g. Vercel → Render):
# VITE_API_URL=https://your-backend.onrender.com/api
# VITE_SOCKET_URL=https://your-backend.onrender.com
